# NextAuth local settings
NEXTAUTH_SECRET=replace-with-random-secret-from-openssl-rand-base64-32
NEXTAUTH_URL=http://localhost:3000

# Google OAuth; allowed email is hello@neodym.ai initially
GOOGLE_CLIENT_ID=replace-with-google-client-id
GOOGLE_CLIENT_SECRET=replace-with-google-client-secret
ALLOWED_GOOGLE_EMAILS=hello@neodym.ai

# IMPORTANT: bcrypt hashes contain `$`. In Next.js env files, escape every `$` as `\$`.
# Generate an escaped value with: node scripts/generate-admin-password-hash.mjs admin123
ADMIN_PASSWORD_HASH=\$2b\$12\$replace-with-escaped-bcrypt-hash

# Must be exactly 32 bytes/chars for local dev
CREDENTIAL_ENCRYPTION_KEY=replace-with-32-byte-secret-key!!

# Supabase
SUPABASE_URL=replace-with-supabase-url
SUPABASE_SERVICE_ROLE_KEY=replace-with-service-role-key
SUPABASE_ANON_KEY=replace-with-anon-key
DATABASE_URL=postgresql://db-user:***@db-host:5432/postgres

# Private dashboard SSO provider
SSO_ISSUER_URL=http://localhost:3000
SSO_CODE_TTL_SECONDS=120
SSO_TOKEN_TTL_SECONDS=900
SSO_SIGNING_SECRET=replace-with-separate-long-random-sso-secret
